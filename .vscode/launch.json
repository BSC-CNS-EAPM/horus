{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Horus server mode",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/Horus.py",
            "console": "integratedTerminal",
            "args": [
                "--server",
                "--debug",
                "--host",
                "0.0.0.0",
                "--port",
                "3000"
            ]
        },
        {
            "name": "Debug Horus desktop (browser) mode",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/Horus.py",
            "console": "integratedTerminal",
            "args": [
                "--browser",
                "--debug",
                "--host",
                "0.0.0.0"
            ]
        },
        {
            "name": "Run Horus desktop (App) mode",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/Horus.py",
            "console": "integratedTerminal",
        },
    ]
}