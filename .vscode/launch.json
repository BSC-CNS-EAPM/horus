{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Horus App mode",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/Horus.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "--debug",
                "--host",
                "0.0.0.0",
                "--port",
                "3000"
            ]
        },
        {
            "name": "Debug Horus App mode (devparcel)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/Horus.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "--debug",
                "--host",
                "0.0.0.0",
                "--port",
                "3000",
                "--url",
                "http://0.0.0.0:3001"
            ]
        },
        {
            "name": "Debug Horus server mode",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/Horus.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "--server",
                "--debug",
                "--host",
                "0.0.0.0",
                "--port",
                "3000"
            ]
        },
        {
            "name": "Debug Horus WebApp mode",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/Horus.py",
            "console": "integratedTerminal",
            "args": [
                "--webapp",
                "--debug",
                "--host",
                "0.0.0.0",
                "--port",
                "3000"
            ]
        },
        {
            "name": "Debug Horus desktop (browser) mode",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/Horus.py",
            "console": "integratedTerminal",
            "args": [
                "--browser",
                "--debug",
                "--host",
                "0.0.0.0"
            ]
        },
        {
            "name": "Run Horus desktop (App) mode",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/Horus.py",
            "console": "integratedTerminal",
        },
        {
            "name": "Debug Horus run flow mode",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/Horus.py",
            "console": "integratedTerminal",
            "args": [
                "--debug",
                "--flow",
                "Tests/TestFlows/molstarapi_background.flow",
                "-i",
                "1"
            ]
        },
        {
            "name": "Horus server mode",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/Horus.py",
            "console": "integratedTerminal",
            "args": [
                "--server",
                "--host",
                "0.0.0.0",
                "--port",
                "3000"
            ]
        },
        {
            "name": "Debug Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "Tests/",
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Debug Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "Tests/",
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Debug Selected Test",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "Tests/",
                "-k",
                "${input:pickTest}"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
    ],
    "inputs": [
        {
            "id": "pickTest",
            "description": "Test function name",
            "default": "test_flow_run_flow_post_full_app",
            "type": "promptString"
        }
    ]
}