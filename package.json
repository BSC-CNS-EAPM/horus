{
  "name": "horus",
  "version": "0.0.1",
  "description": "Molecular visualizer from EAPM group at BSC",
  "source": "Views/Main/index.html",
  "browserslist": "Safari >= 9",
  "alias": {
    "@/*": "./Views/$1",
    "@components/*": "./Views/Components/$1"
  },
  "scripts": {
    "test": "python -m pytest Tests/ -vv -W ignore::DeprecationWarning",
    "dev": "python Horus.py -s -d -h 0.0.0.0 -p 3000",
    "webapp": "python Horus.py -d -w",
    "buildparcel": "parcel build Views/**/*.html --dist-dir GUI --no-scope-hoist --public-url ./ && cp -r Views/Favicon/ GUI/Favicon && cp Resources/horus.png GUI/Favicon/logo.png",
    "devparcel:main": "parcel --port 3001 --host 0.0.0.0 --no-cache Views/Main/index.html",
    "devparcel:login": "parcel Views/Login/login.html --port 3001 --host 0.0.0.0",
    "devparcel:about": "parcel Views/About/index.html --port 3001 --host 0.0.0.0",
    "devparcel:browsermode": "parcel Views/BrowserMode/index.html --port 3001 --host 0.0.0.0",
    "devparcel:pluginsmanager": "parcel Views/PluginsManager/index.html --port 3001 --host 0.0.0.0",
    "devparcel:remoteserver": "parcel Views/Remotes/index.html --port 3001 --host 0.0.0.0",
    "devparcel:settings": "parcel Views/Settings/index.html --port 3001 --host 0.0.0.0",
    "devparcel:admintools": "parcel Views/Login/admintools.html --port 3001 --host 0.0.0.0",
    "build": "npm run buildparcel && sh Devtools/Compile/build_horus.sh",
    "compile": "sh Devtools/Compile/build_horus.sh",
    "distribute": "run-script-os",
    "distribute:linux": "./Devtools/Package/linux.sh",
    "distribute:darwin": "./Devtools/Package/macos.sh",
    "libs-debian": "sudo apt-get install -y libgirepository1.0-dev gcc libgtk-4-dev",
    "libs-rhel": "sudo dnf install gcc gobject-introspection-devel cairo-gobject-devel pkg-config python3-devel gtk3-devel",
    "clean": "sh Devtools/clean.sh",
    "clean-all": "npm run clean && rm -rf dist GUI",
    "clean-build": "rm -rf build",
    "build-horusapi": "sh Devtools/Compile/build_horusapi.sh",
    "build-debug": "sh Devtools/Compile/build_debug.sh",
    "docs-clean": "rm -rf HorusAPI/docs/build/*",
    "docs-build": "sh Devtools/build_docs.sh"
  },
  "author": "BSC",
  "license": "MIT",
  "keywords": [
    "molecules",
    "visualizer",
    "drug-discovery"
  ],
  "dependencies": {
    "@dnd-kit/core": "6.0.8",
    "@dnd-kit/modifiers": "6.0.1",
    "@dnd-kit/sortable": "^7.0.2",
    "@headlessui/react": "1.7.14",
    "@heroicons/react": "2.0.18",
    "@mantine/core": "^7.17.2",
    "@mantine/hooks": "^7.17.2",
    "@mantine/modals": "^7.17.2",
    "@mantine/nprogress": "^7.17.2",
    "@melloware/react-logviewer": "^5.0.6",
    "@monaco-editor/react": "^4.6.0",
    "@react-hook/resize-observer": "^2.0.2",
    "@tabler/icons-react": "^3.34.1",
    "@tanstack/react-query": "^5.52.1",
    "@types/react": "^19.0.14",
    "@xyflow/react": "^12.4.4",
    "ag-grid-community": "^31.3.2",
    "ag-grid-react": "^31.3.2",
    "chonky": "2.3.2",
    "chonky-icon-fontawesome": "2.3.2",
    "develop": "^1.0.0",
    "devlop": "^1.1.0",
    "dockview-react": "^4.2.3",
    "i18next": "22.4.15",
    "i18next-browser-languagedetector": "7.0.1",
    "immutability-helper": "3.1.1",
    "js-beautify": "^1.15.4",
    "marked": "^15.0.12",
    "molstar": "^4.5.0",
    "monaco-editor": "^0.52.0",
    "plotly.js-dist": "^2.35.2",
    "rc-slider": "10.4.0",
    "react": "18.2.0",
    "react-console-emulator": "5.0.2",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "18.2.0",
    "react-ga4": "^2.1.0",
    "react-i18next": "12.2.2",
    "react-resizable-panels": "0.0.51",
    "react-router": "6.11.2",
    "react-router-dom": "6.11.2",
    "react-simple-captcha": "9.3.1",
    "react-xarrows": "2.0.2",
    "socket.io": "4.8.0",
    "socket.io-client": "4.8.0",
    "use-undoable": "^5.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.7",
    "@babel/core": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "@babel/preset-typescript": "^7.24.7",
    "@parcel/babel-preset-env": "^2.12.0",
    "@parcel/config-default": "2.12.0",
    "@parcel/core": "^2.14.4",
    "@parcel/packager-raw-url": "2.12.0",
    "@parcel/transformer-sass": "2.12.0",
    "@parcel/transformer-webmanifest": "2.12.0",
    "@types/bun": "1.0.5",
    "@types/react-dom": "^19.0.6",
    "@types/react-virtualized": "^9.21.30",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "autoprefixer": "10.4.14",
    "buffer": "5.7.1",
    "core-js": "^3.37.1",
    "crypto-browserify": "^3.12.1",
    "develop": "^1.0.0",
    "devlop": "^1.1.0",
    "eslint": "8.48.0",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-prettier": "9.1.0",
    "eslint-config-standard-with-typescript": "37.0.0",
    "eslint-plugin-compat": "4.2.0",
    "eslint-plugin-import": "2.28.0",
    "eslint-plugin-jsx-a11y": "6.8.0",
    "eslint-plugin-n": "16.0.1",
    "eslint-plugin-prettier": "5.1.3",
    "eslint-plugin-promise": "6.1.1",
    "eslint-plugin-react": "7.33.2",
    "eslint-plugin-react-hooks": "4.6.0",
    "events": "3.3.0",
    "fp-ts": "2.16.2",
    "husky": "9.0.10",
    "i18next": "22.4.15",
    "i18next-browser-languagedetector": "7.0.1",
    "license-checker-rseidelsohn": "^4.4.2",
    "lint-staged": "15.2.10",
    "parcel": "^2.14.4",
    "parcel-reporter-static-files-copy": "1.5.3",
    "parcel-resolver-ignore": "2.2.0",
    "path-browserify": "^1.0.1",
    "postcss": "^8.4.47",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.3.3",
    "process": "0.11.10",
    "react-virtualized": "^9.22.5",
    "regenerator-runtime": "^0.14.1",
    "run-script-os": "1.1.6",
    "stream-browserify": "^3.0.0",
    "string_decoder": "1.3.0",
    "tailwindcss": "3.3.2",
    "typescript": "5.1.6",
    "vm-browserify": "^1.1.2"
  },
  "@parcel/resolver-default": {
    "packageExports": true
  },
  "parcelIgnore": [
    "/Static*"
  ],
  "staticFiles": {
    "staticPath": "Views/Static",
    "staticOutPath": "Static"
  },
  "trustedDependencies": [
    "core-js"
  ],
  "packageManager": "yarn@4.7.0+sha512.5a0afa1d4c1d844b3447ee3319633797bcd6385d9a44be07993ae52ff4facabccafb4af5dcd1c2f9a94ac113e5e9ff56f6130431905884414229e284e37bb7c9"
}
