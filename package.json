{
  "name": "horus",
  "version": "0.0.1",
  "description": "Molecular visualizer from nostrum Biodiscovery",
  "source": "Views/Main/index.html",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "buildparcel": "parcel build Views/**/*.html --dist-dir GUI",
    "devparcel": "parcel Views/Main/index.html",
    "build": "npm run buildparcel && python compile.py build_ext && pyinstaller build.spec --noconfirm",
    "requirements": "npm install && conda env create -f conda_horus.yaml -n horus"
  },
  "author": "Nostrum Biodiscovery",
  "license": "MIT",
  "keywords": [
    "molecules",
    "nbdsuite",
    "visualizer",
    "drug-discovery"
  ],
  "dependencies": {
    "molstar": "^3.34.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@parcel/transformer-sass": "^2.8.3",
    "autoprefixer": "^10.4.14",
    "buffer": "^5.7.1",
    "parcel": "^2.8.3",
    "postcss": "^8.4.23",
    "process": "^0.11.10",
    "run-script-os": "^1.1.6",
    "tailwindcss": "^3.3.2"
  }
}