{
  "name": "horus",
  "version": "0.0.1",
  "description": "Molecular visualizer from nostrum Biodiscovery",
  "source": "Views/Main/index.html",
  "scripts": {
    "test": "python -m pytest",
    "buildparcel": "parcel build Views/**/*.html --dist-dir GUI --no-scope-hoist && npm run parcel-nbdsuite && cp -r Views/Favicon/ GUI/Favicon",
    "devparcel": "parcel Views/**/*.html",
    "build": "npm run buildparcel && python Devtools/Compile/compile.py build_ext && pyinstaller Devtools/Compile/build.spec --noconfirm",
    "distribute": "run-script-os",
    "distribute:linux": "./Devtools/Package/linux.sh",
    "distribute:darwin": "./Devtools/Package/macos.sh",
    "requirements": "npm i run-script-os && run-script-os",
    "requirements:linux": "sudo apt-get update && sudo apt-get install -y libgirepository1.0-dev gcc libgtk-3-dev && npm install && conda env create -f Devtools/Environment/conda_horus.yaml -n horus",
    "requirements:darwin": "npm install && conda env create -f Devtools/Environment/conda_horus.yaml -n horus && npm install --global create-dmg",
    "requirements-action": "npm i run-script-os && run-script-os",
    "requirements-action:linux": "sudo apt-get update && sudo apt-get install -y libgirepository1.0-dev gcc libgtk-3-dev && npm install",
    "requirements-action:darwin": "npm install && npm install --global create-dmg",
    "clean": "rm -rf dist build GUI .parcel-cache .pytest_cache AppSupport/DefaultPlugins/NBDSuite/Pages/*",
    "parcel-nbdsuite": "parcel build AppSupport/DefaultPlugins/NBDSuite/dev/nbdsuite.html --dist-dir AppSupport/DefaultPlugins/NBDSuite/Pages --public-url ./",
    "parcel-nbdsuite-dev": "parcel AppSupport/DefaultPlugins/NBDSuite/dev/nbdsuite.html --dist-dir AppSupport/DefaultPlugins/NBDSuite/Pages --public-url ./",
    "build-horusapi": "cd HorusAPI && python setup.py bdist_wheel && cd .."
  },
  "author": "Nostrum Biodiscovery",
  "license": "MIT",
  "keywords": [
    "molecules",
    "nbdsuite",
    "visualizer",
    "drug-discovery"
  ],
  "dependencies": {
    "@dnd-kit/core": "^6.0.8",
    "@dnd-kit/modifiers": "^6.0.1",
    "@dnd-kit/sortable": "^7.0.2",
    "@headlessui/react": "^1.7.14",
    "@heroicons/react": "^2.0.18",
    "@types/react-plotly.js": "^2.6.0",
    "ag-grid-community": "^30.0.3",
    "ag-grid-react": "^30.0.4",
    "animejs": "^3.2.1",
    "bootstrap": "^5.2.3",
    "downloadjs": "^1.4.7",
    "eslint": "^8.42.0",
    "i18next": "^22.4.15",
    "i18next-browser-languagedetector": "^7.0.1",
    "immutability-helper": "^3.1.1",
    "molstar": "^3.34.0",
    "plotly.js": "^2.24.3",
    "react": "^18.2.0",
    "react-bootstrap": "^2.7.4",
    "react-console-emulator": "^5.0.2",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.2.0",
    "react-i18next": "^12.2.2",
    "react-plotly.js": "^2.6.0",
    "react-resizable-panels": "^0.0.51",
    "react-router": "^6.11.2",
    "react-router-dom": "^6.11.2",
    "react-xarrows": "^2.0.2",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.6.1",
    "styled-components": "^5.3.10"
  },
  "devDependencies": {
    "@parcel/packager-raw-url": "^2.9.3",
    "@parcel/transformer-sass": "^2.8.3",
    "@parcel/transformer-webmanifest": "^2.9.3",
    "autoprefixer": "^10.4.14",
    "buffer": "^5.7.1",
    "parcel": "^2.8.3",
    "postcss": "^8.4.23",
    "prettier": "2.8.8",
    "process": "^0.11.10",
    "run-script-os": "^1.1.6",
    "tailwindcss": "^3.3.2"
  }
}
